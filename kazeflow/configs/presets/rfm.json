{
  "_note": "Rectified Flow Matching (RFM) preset — recommended for all use cases",
  "model": {
    "architecture": "rfm",
    "flow_matching": {
      "mel_channels": 128,
      "hidden_channels": 256,
      "cond_channels": 768,
      "gin_channels": 256,
      "n_layers": 12,
      "kernel_size": 7,
      "dilation_rate": 2,
      "dropout": 0.1,
      "velocity_weighting": true,
      "t_sampling": "logit_normal",
      "t_logit_mean": 0.0,
      "t_logit_std": 1.0,
      "cfg_dropout": 0.1
    },
    "vocoder_type": "chouwa_gan",
    "vocoder": {
      "mel_channels": 128,
      "upsample_rates": [8, 5, 6, 2],
      "upsample_initial_channel": 384,
      "upsample_kernel_sizes": [16, 10, 12, 4],
      "resblock_kernel_sizes": [3, 7, 11],
      "resblock_dilation_sizes": [[1, 3, 5], [1, 3, 5], [1, 3, 5]],
      "gin_channels": 256,
      "n_harmonics": 6,
      "use_checkpoint": false,
      "n_fft": 2048,
      "win_length": 2048
    },
    "discriminator": {
      "stft_configs": [
        {"n_fft": 2048, "hop_length": 512, "win_length": 2048},
        {"n_fft": 1024, "hop_length": 256, "win_length": 1024}
      ],
      "stft_channels": 64,
      "stft_max_channels": 128,
      "stft_n_layers": 3,
      "mpd_periods": [2, 3, 5],
      "mpd_channels": 64,
      "mpd_max_channels": 256,
      "mpd_n_layers": 4,
      "univhd_n_harmonics": 10,
      "univhd_bins_per_octave": 24,
      "univhd_channels": 64,
      "univhd_n_fft": 2048,
      "univhd_hop_length": 512,
      "use_spectral_norm": false,
      "use_san": true
    },
    "speaker_embed_dim": 256,
    "n_speakers": 1
  },
  "train": {
    "precision": "tf32_bf16",
    "torch_compile": false,
    "batch_size": 8,
    "epochs": 1000,
    "save_every": 50,
    "log_every": 100,
    "learning_rate_flow": 0.0002,
    "learning_rate_vocoder": 0.0002,
    "learning_rate_disc": 0.0002,
    "betas_flow": [0.95, 0.999],
    "betas_vocoder": [0.9, 0.999],
    "betas_disc": [0.9, 0.999],
    "weight_decay": 0.01,
    "lr_scheduler": "cosine",
    "lr_eta_min_ratio": 0.01,
    "grad_clip_flow": 3.0,
    "grad_clip_vocoder": 75.0,
    "grad_clip_disc": 100.0,
    "cfm_grad_accum": 1,
    "ode_steps_train_min": 2,
    "ode_steps_train_max": 4,
    "ode_method_train": "midpoint",
    "gt_mel_ratio": 0.3,
    "c_gen": 0.6,
    "c_mel": 2.0,
    "c_fm": 1.0,
    "c_mrstft": 1.0,
    "c_env": 0.5,
    "c_phase": 0.1,
    "c_r1": 0.0,
    "c_lecam": 0.02,
    "lecam_ema_decay": 0.999,
    "gan_loss_type": "soft_hinge",
    "ema_decay": 0.999,
    "use_gradient_balancer": false,
    "num_workers": 4,
    "pin_memory": true,
    "seed": 42
  },
  "inference": {
    "ode_steps": 4,
    "ode_method": "midpoint",
    "guidance_scale": 1.5,
    "f0_method": "rmvpe",
    "f0_shift": 0,
    "index_rate": 0.0,
    "silence_threshold_db": -40.0
  }
}
